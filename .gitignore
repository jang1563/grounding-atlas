# ── Large / re-fetchable data ────────────────────────────────────────
# Provenance: re-fetch via the per-branch setup scripts (e.g. eval/setup_data_*.sh).
# Public reference DBs live under */data/raw/ (AlphaMissense ~1.1G, three ClinVar
# releases ~1.2G, UniProt FASTA, ProteinGym DMS) and must not be committed.
**/data/raw/
*.gz
*.db
*.sqlite
*.sqlite3
# Large derived table (~184k variants); the balanced eval CSVs are the committed inputs.
variant_grounding/data/variant_clinvar_full.csv

# Internal working notes (strategy, application framing, session checkpoints) — local only
internal/

# AlphaGenome-derived scores (non-commercial terms; regenerate via signal/regulatory/)
signal/regulatory/variant_scores.csv
signal/regulatory/eqtl_ceiling_gate.csv

# Synthetic --dry-run benchmark artifacts (pipeline check only, not a real model run)
results/benchmark/dry/

# Inspect (inspect_ai) eval logs
logs/

# Experiment-2 molecular-FM embeddings (28MB, regenerable in ~2min via eval/sfm_embed_chemberta.py)
signal/sfm_embedding/chemberta_*.npz
signal/sfm_embedding/MoLFormer*.npz

# Experiment-3 reward-head ensembles (regenerable via eval/reward_head_load.py)
signal/reward/
